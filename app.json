{
  "expo": {
    "name": "Andante",
    "slug": "andante",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/andante_icon.png",
    "scheme": "andante",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#08090F",
    "android": {
      "package": "com.boris.andante",
      "adaptiveIcon": {
        "backgroundColor": "#08090F",
        "foregroundImage": "./assets/andante_icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#08090F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "color": "#08090F"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "HabitWidget",
              "label": "Andante habit",
              "description": "Tile grid and one-tap check for a habit",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "previewImage": "./assets/widget-preview.png",
              "resizeMode": "horizontal|vertical",
              "widgetFeatures": "reconfigurable",
              "updatePeriodMillis": 3600000
            }
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "38e5fe67-de4e-4d01-9553-09d3efd15104"
      }
    }
  }
}
